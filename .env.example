# Environment
# Local default: SQLite (no Docker required)
DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"

# Optional PostgreSQL (see docker-compose.yml):
# DATABASE_URL="postgresql://erp:erp@localhost:5432/erp_modular?schema=public"
# Then set prisma schema provider to "postgresql" and re-run migrate.
