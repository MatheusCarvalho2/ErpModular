generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ServiceOrderStatusRole {
  OPERATIONAL
  COMPLETED
  CANCELLED
}

model Company {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  services         Service[]
  products         Product[]
  clients          Client[]
  clientProducts   ClientProduct[]
  permissionGroups PermissionGroup[]
  serviceOrderStatuses ServiceOrderStatus[]
  serviceOrders         ServiceOrder[]
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  passwordHash       String
  name               String
  active             Boolean      @default(true)
  isPlatformOperator Boolean      @default(false)
  mustChangePassword Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  membership         Membership?
}

model Membership {
  id                String          @id @default(cuid())
  userId            String          @unique
  companyId         String
  permissionGroupId String
  createdAt         DateTime        @default(now())
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissionGroup   PermissionGroup @relation(fields: [permissionGroupId], references: [id])

  @@index([companyId])
  @@index([permissionGroupId])
}

model PermissionGroup {
  id          String            @id @default(cuid())
  companyId   String
  name        String
  /// ADMIN | OPERADORES | null (custom)
  systemKey   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  grants      PermissionGrant[]
  memberships Membership[]

  @@unique([companyId, name])
  @@index([companyId])
}

model PermissionGrant {
  id                String          @id @default(cuid())
  permissionGroupId String
  permissionKey     String
  permissionGroup   PermissionGroup @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)

  @@unique([permissionGroupId, permissionKey])
}

model Service {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  nameNormalized     String
  description        String
  productDescription String?
  priceCents         Int?
  durationMinutes    Int?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceOrders      ServiceOrder[]

  @@index([companyId, active])
}

model Product {
  id             String          @id @default(cuid())
  companyId      String
  name           String
  nameNormalized String
  description    String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientProducts ClientProduct[]

  @@index([companyId, active])
}

model Client {
  id              String          @id @default(cuid())
  companyId       String
  name            String
  phone           String
  phoneNormalized String
  personGroupId   String?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientProducts  ClientProduct[]
  serviceOrders   ServiceOrder[]

  @@index([companyId, active])
  @@index([companyId, phoneNormalized])
  @@index([companyId, personGroupId])
}

model ClientProduct {
  id                   String   @id @default(cuid())
  companyId            String
  clientId             String
  productId            String
  identifier           String
  identifierNormalized String
  serialNumber         String?
  notes                String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  serviceOrders        ServiceOrder[]

  @@index([companyId, active])
  @@index([clientId, active])
  @@index([companyId, identifierNormalized])
}

model ServiceOrderStatus {
  id               String                 @id @default(cuid())
  companyId        String
  name             String
  nameNormalized   String
  sortOrder        Int
  isDefaultInitial Boolean                @default(false)
  role             ServiceOrderStatusRole
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceOrders    ServiceOrder[]

  @@index([companyId, active])
  @@index([companyId, sortOrder])
}

model ServiceOrder {
  id              String             @id @default(cuid())
  companyId       String
  serviceId       String
  clientId        String
  clientProductId String
  statusId        String
  priceCents      Int
  workDescription String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service         Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientProduct   ClientProduct      @relation(fields: [clientProductId], references: [id], onDelete: Restrict)
  status          ServiceOrderStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)

  @@index([companyId, statusId])
  @@index([companyId, createdAt])
  @@index([serviceId])
  @@index([clientId])
  @@index([clientProductId])
}
